# ─── Required ─────────────────────────────────────────────────────────────────
# Gemini is the default LLM provider
GEMINI_API_KEY=your_gemini_api_key_here
# GOOGLE_API_KEY can be used instead of GEMINI_API_KEY

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# Comma-separated list of allowed frontend origins (required in production)
CORS_ORIGINS=https://your-frontend.onrender.com

# ─── LLM Configuration ────────────────────────────────────────────────────────
# GEMINI_MODEL=gemini-2.5-flash
# LLM_MAX_TOKENS=4096
# LLM_MAX_TOKENS_LARGE=8192
# LLM_TEMPERATURE=0.1

# Alternative providers (optional)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── Storage ──────────────────────────────────────────────────────────────────
# STORAGE_PROVIDER=local   # "local" (default) or "s3"
# GENERATED_DIR=generated

# S3-compatible storage (required when STORAGE_PROVIDER=s3)
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_PREFIX=projects
# S3_ENDPOINT=              # leave blank for AWS; set for Cloudflare R2 / MinIO
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# RATE_LIMIT_API=30         # requests per minute for general API routes
# RATE_LIMIT_GENERATION=10  # requests per minute for generation routes

# ─── Generation Tuning ────────────────────────────────────────────────────────
# MAX_FILE_TIMEOUT=240000   # ms per file (default 4 min)
# MAX_TOTAL_TIMEOUT=600000  # ms total (default 10 min)
# MAX_RETRIES=3
# CONCURRENT_BATCH=3

# ─── Agent Pipeline ───────────────────────────────────────────────────────────
# AGENT_MAX_STEPS=500
# AGENT_MAX_FIX_ATTEMPTS=3
# AGENT_MAX_FIX_ATTEMPTS_TRUNCATION=3

# ─── Auth (optional) ──────────────────────────────────────────────────────────
# JWT_SECRET=change_me_min_32_chars_random_string
# JWT_REFRESH_SECRET=change_me_another_32_chars_random

# ─── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL=info            # debug | info | warn | error
