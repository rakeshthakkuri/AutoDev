# ─── Required (Gemini is the default LLM) ─────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# Or use GOOGLE_API_KEY instead of GEMINI_API_KEY

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── LLM Configuration ───────────────────────────────────────────────────────
# LLM_PROVIDER=gemini
# GEMINI_MODEL=gemini-2.5-flash
# LLM_MAX_TOKENS=4096
# LLM_MAX_TOKENS_LARGE=8192
# LLM_TEMPERATURE=0.1

# ─── Anthropic (optional, if LLM_PROVIDER=anthropic) ───────────────────────────
# ANTHROPIC_API_KEY=your_anthropic_key
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── OpenAI (future) ─────────────────────────────────────────────────────────
# OPENAI_API_KEY=your_openai_key
# OPENAI_MODEL=gpt-4o

# ─── Rate Limiting ───────────────────────────────────────────────────────────
# RATE_LIMIT_API=30
# RATE_LIMIT_GENERATION=10

# ─── Generation (increase if you hit "Phase timeout exceeded") ─────────────────
# MAX_FILE_TIMEOUT=240000
# MAX_TOTAL_TIMEOUT=600000
# MAX_RETRIES=3
# CONCURRENT_BATCH=3

# ─── Logging ─────────────────────────────────────────────────────────────────
# LOG_LEVEL=info
