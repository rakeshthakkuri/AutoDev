# ─── Required (Gemini is the default LLM) ─────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# Or use GOOGLE_API_KEY instead of GEMINI_API_KEY

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── PostgreSQL (Phase 1+) ────────────────────────────────────────────────────
# DATABASE_URL=postgres://user:pass@localhost:5432/appdb

# ─── Storage (Phase 1.5 / 2.3) ─────────────────────────────────────────────────
# STORAGE_PROVIDER=local
# GENERATED_DIR=generated
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_PREFIX=projects
# S3_ENDPOINT=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ─── Queue / worker (Phase 2) ─────────────────────────────────────────────────
# WORKER_CONCURRENCY=3
# PROJECT_RETENTION_DAYS=7
# CLEANUP_INTERVAL_HOURS=24

# ─── Auth / API (Phase 3) ─────────────────────────────────────────────────────
# JWT_SECRET=change_me_min_32_chars_random_string
# JWT_REFRESH_SECRET=change_me_another_32_chars_random
# FREE_TIER_MONTHLY_GENERATIONS=50

# ─── LLM Configuration ───────────────────────────────────────────────────────
# GEMINI_MODEL=gemini-2.5-flash
# LLM_MAX_TOKENS=4096
# LLM_MAX_TOKENS_LARGE=8192
# LLM_TEMPERATURE=0.1

# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── Rate Limiting ───────────────────────────────────────────────────────────
# RATE_LIMIT_API=30
# RATE_LIMIT_GENERATION=10

# ─── Generation ───────────────────────────────────────────────────────────────
# MAX_FILE_TIMEOUT=240000
# MAX_TOTAL_TIMEOUT=600000
# MAX_RETRIES=3
# CONCURRENT_BATCH=3

# ─── Agent Pipeline ───────────────────────────────────────────────────────────
# AGENT_MAX_STEPS=500
# AGENT_MAX_FIX_ATTEMPTS=2

# ─── Logging ─────────────────────────────────────────────────────────────────
# LOG_LEVEL=info
