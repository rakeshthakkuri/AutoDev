# ─── Required ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_api_key_here

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── LLM Configuration ───────────────────────────────────────────────────────
# LLM_PROVIDER=anthropic
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# LLM_MAX_TOKENS=4096
# LLM_MAX_TOKENS_LARGE=8192
# LLM_TEMPERATURE=0.1

# ─── OpenAI (future) ─────────────────────────────────────────────────────────
# OPENAI_API_KEY=your_openai_key
# OPENAI_MODEL=gpt-4o

# ─── Rate Limiting ───────────────────────────────────────────────────────────
# RATE_LIMIT_API=30
# RATE_LIMIT_GENERATION=10

# ─── Generation ──────────────────────────────────────────────────────────────
# MAX_FILE_TIMEOUT=120000
# MAX_TOTAL_TIMEOUT=300000
# MAX_RETRIES=3
# CONCURRENT_BATCH=3

# ─── Logging ─────────────────────────────────────────────────────────────────
# LOG_LEVEL=info
