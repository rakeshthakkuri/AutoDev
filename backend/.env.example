# ─── Required ─────────────────────────────────────────────────────────────────
# Pick exactly one provider. The system "pins" to it — there is NO automatic
# crossover to a different provider. To swap, change this var and the matching key.
LLM_PRIMARY_PROVIDER=gemini   # "gemini" or "anthropic"

# Provide the API key for whichever provider is set above.
# If LLM_PRIMARY_PROVIDER=gemini:
GEMINI_API_KEY=your_gemini_api_key_here
# GOOGLE_API_KEY can be used instead of GEMINI_API_KEY

# If LLM_PRIMARY_PROVIDER=anthropic:
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# Comma-separated list of allowed frontend origins (required in production)
CORS_ORIGINS=https://your-frontend.onrender.com

# ─── LLM Provider Tuning (optional) ───────────────────────────────────────────
# Gemini-specific
# GEMINI_MODEL=gemini-2.5-flash
# LLM_MAX_TOKENS=4096
# LLM_MAX_TOKENS_LARGE=8192
# LLM_TEMPERATURE=0.1

# Anthropic-specific (default model: Haiku 4.5)
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_MAX_TOKENS=8192

# ─── LLM Retry Policy (optional) ──────────────────────────────────────────────
# Worst-case wait with defaults: 1+2+4+8+16+30 = ~61s before surfacing an error.
# LLM_RETRY_MAX_ATTEMPTS=6
# LLM_RETRY_INITIAL_MS=1000
# LLM_RETRY_MAX_MS=30000
# LLM_RETRY_JITTER_MS=250

# ─── Storage ──────────────────────────────────────────────────────────────────
# STORAGE_PROVIDER=local   # "local" (default) or "s3"
# GENERATED_DIR=generated

# S3-compatible storage (required when STORAGE_PROVIDER=s3)
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_PREFIX=projects
# S3_ENDPOINT=              # leave blank for AWS; set for Cloudflare R2 / MinIO
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# RATE_LIMIT_API=30         # requests per minute for general API routes
# RATE_LIMIT_GENERATION=10  # requests per minute for generation routes

# ─── Generation Tuning ────────────────────────────────────────────────────────
# MAX_FILE_TIMEOUT=240000   # ms per file (default 4 min)
# MAX_TOTAL_TIMEOUT=600000  # ms total (default 10 min)
# MAX_RETRIES=3
# CONCURRENT_BATCH=3

# ─── Agent Pipeline ───────────────────────────────────────────────────────────
# AGENT_MAX_STEPS=500
# AGENT_MAX_FIX_ATTEMPTS=3
# AGENT_MAX_FIX_ATTEMPTS_TRUNCATION=3

# ─── Auth (optional) ──────────────────────────────────────────────────────────
# JWT_SECRET=change_me_min_32_chars_random_string
# JWT_REFRESH_SECRET=change_me_another_32_chars_random

# ─── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL=info            # debug | info | warn | error
